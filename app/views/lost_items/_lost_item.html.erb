<div id="<%= dom_id lost_item %>" class="bg-white shadow-md rounded-lg p-5 mb-6 w-full sm:w-auto space-y-4">
  <!-- Title -->
  <div>
    <strong class="block font-medium text-gray-700 mb-1">Title:</strong>
    <p><%= lost_item.title %></p>
  </div>

  <!-- Description -->
  <div>
    <strong class="block font-medium text-gray-700 mb-1">Description:</strong>
    <p><%= lost_item.description %></p>
  </div>

  <!-- Location -->
  <div>
    <strong class="block font-medium text-gray-700 mb-1">Location:</strong>
    <p><%= lost_item.location %></p>
  </div>

  <!-- Status -->
  <div>
    <strong class="block font-medium text-gray-700 mb-1">Status:</strong>
    <span class="inline-block px-2 py-1 rounded text-white bg-indigo-600 text-sm"><%= lost_item.status %></span>
  </div>

  <!-- User Info -->
  <div>
    <strong class="block font-medium text-gray-700 mb-1">User ID:</strong>
    <p><%= lost_item.user_id %></p>
  </div>

  <!-- 📷 Image Preview -->
  <% if lost_item.image.attached? %>
    <div>
      <strong class="block font-medium text-gray-700 mb-1">Image:</strong>
      <%= image_tag lost_item.image.variant(resize_to_limit: [300, 200]), class: "rounded shadow-md border w-64 h-auto" %>
    </div>
  <% end %>

  <!-- 🔧 Action Buttons -->
  <% if user_signed_in? && (current_user.admin? || current_user == lost_item.user) %>
    <div class="flex space-x-4 mt-4">
      <%= link_to 'Edit', edit_lost_item_path(lost_item), class: "px-4 py-2 bg-yellow-500 text-white rounded hover:bg-yellow-600 text-sm" %>
      <%= link_to 'Delete', lost_item, method: :delete, data: { confirm: 'Are you sure?' }, class: "px-4 py-2 bg-red-600 text-white rounded hover:bg-red-700 text-sm" %>
    </div>
  <% end %>
</div>
