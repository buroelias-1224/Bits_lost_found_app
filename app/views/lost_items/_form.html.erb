<%= form_with(model: lost_item, local: true, html: { multipart: true }, class: "contents") do |form| %>
  <% if lost_item.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(lost_item.errors.count, "error") %> prohibited this lost item from being saved:</h2>
      <ul class="list-disc ml-6">
        <% lost_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Title -->
  <div class="my-5">
    <%= form.label :title %>
    <%= form.text_field :title, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {
      "border-gray-400 focus:outline-blue-600": lost_item.errors[:title].none?,
      "border-red-400 focus:outline-red-600": lost_item.errors[:title].any?
    }] %>
  </div>

  <!-- Description -->
  <div class="my-5">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {
      "border-gray-400 focus:outline-blue-600": lost_item.errors[:description].none?,
      "border-red-400 focus:outline-red-600": lost_item.errors[:description].any?
    }] %>
  </div>

  <!-- Location -->
  <div class="my-5">
    <%= form.label :location %>
    <%= form.text_field :location, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {
      "border-gray-400 focus:outline-blue-600": lost_item.errors[:location].none?,
      "border-red-400 focus:outline-red-600": lost_item.errors[:location].any?
    }] %>
  </div>

  <!-- Status -->
  <div class="my-5">
    <%= form.label :status %>
    <%= form.select :status, ["Lost", "Found", "Returned"], {}, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {
      "border-gray-400 focus:outline-blue-600": lost_item.errors[:status].none?,
      "border-red-400 focus:outline-red-600": lost_item.errors[:status].any?
    }] %>
  </div>

  <!-- User ID (optional for now, could be auto-handled in controller) -->
  <div class="my-5">
    <%= form.label :user_id %>
    <%= form.text_field :user_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {
      "border-gray-400 focus:outline-blue-600": lost_item.errors[:user_id].none?,
      "border-red-400 focus:outline-red-600": lost_item.errors[:user_id].any?
    }] %>
  </div>

  <!-- 📷 Image Upload -->
  <div class="my-5">
    <%= form.label :image, class: "block font-medium text-gray-700" %>
    <%= form.file_field :image, class: "mt-1 block w-full" %>
  </div>

  <!-- Submit Button -->
  <div class="inline mt-6">
    <%= form.submit "Submit", class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium cursor-pointer" %>
  </div>
<% end %>
